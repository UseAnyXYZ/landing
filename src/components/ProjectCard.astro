---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="rounded-lg border border-slate-700 p-6">
  <div class="flex items-center gap-3">
    <h3 class="text-lg font-semibold text-white">{project.name}</h3>
    <span class="rounded-full bg-slate-800 px-2.5 py-0.5 text-xs text-slate-400">
      {project.license}
    </span>
    <span class="rounded-full bg-slate-800 px-2.5 py-0.5 text-xs text-slate-400">
      {project.language}
    </span>
  </div>
  <p class="mt-3 text-sm leading-relaxed text-slate-400">
    {project.description}
  </p>
  <div class="mt-4 flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span class="rounded-md bg-slate-800 px-2.5 py-1 text-xs text-slate-300">
        {tag}
      </span>
    ))}
  </div>
  <div class="mt-4 flex gap-4">
    {project.links.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-sky-400 hover:text-sky-300 transition-colors"
      >
        {link.label} &rarr;
      </a>
    ))}
  </div>
</div>
